<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= site.name %> — заказ печати</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
  <script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>
</head>
<body>
  <header class="hero compact-hero">
    <div class="container hero-row">
      <div class="hero-empty"></div>
      <img src="<%= site.logoPath %>" alt="<%= site.name %>" class="brand-logo brand-logo-large" />
      <aside class="hero-side">
        <div class="hero-side-item"><span>Адрес</span><strong><%= site.address %></strong></div>
        <div class="hero-side-item"><span>Телефон</span><strong><%= site.phone %></strong></div>
      </aside>
    </div>
  </header>

  <main class="container app-grid">
    <section class="panel glow-panel">
      <div class="panel-head"><h1>Заказ печати</h1></div>
      <% if (success) { %><div class="alert success">Заказ отправлен.</div><% } %>
      <% if (error) { %><div class="alert error"><%= error %></div><% } %>

      <form id="orderForm" class="order-form" action="/order" method="post" enctype="multipart/form-data">
        <div class="field field-full">
          <label>Форматы</label>
          <div class="format-toggle-list compact-two-row" id="format-toggle-list">
            <% paperOptions.forEach(function(format) { %>
              <button type="button" class="format-toggle" data-format-toggle="<%= format %>"><span><%= format %></span></button>
            <% }) %>
          </div>
        </div>

        <div id="selectedFormatsWrap" class="field field-full upload-list"></div>

        <details class="field field-full accordion" open>
          <summary>Контакты</summary>
          <div class="accordion-body grid-2">
            <div class="field"><label>Имя</label><input type="text" name="fullName" required placeholder="Имя" /></div>
            <div class="field"><label>Телефон</label><input type="text" name="phone" required placeholder="Телефон" /></div>
            <div class="field"><label>Email</label><input type="text" name="email" placeholder="Email" /></div>
            <div class="field"><label>Получение</label>
              <select name="deliveryType" id="deliveryType"><option value="pickup">Самовывоз</option><option value="delivery">Доставка</option></select>
            </div>
            <div class="field field-full" id="addressField" style="display:none"><label>Адрес</label><input type="text" name="address" placeholder="Адрес доставки" /></div>
            <div class="field field-full"><label>Комментарий к заказу</label><textarea name="comment" placeholder="Комментарий"></textarea></div>
          </div>
        </details>

        <input type="hidden" name="formatsJson" id="formatsJson" value="[]" />
      </form>
    </section>

    <aside class="right-rail desktop-rail">
      <section class="panel glow-panel summary-panel">
        <div class="panel-head"><h2>Состав заказа</h2></div>
        <div id="summaryList" class="summary-card-list"></div>
        <div class="compact-estimate-box compact-bottom-box">
          <div id="estimateTotal" class="estimate-main">0 ₽</div>
          <p id="estimateNote" class="estimate-note">Добавь файлы</p>
        </div>
      </section>
    </aside>
  </main>

  <div class="mobile-sticky-bar">
    <div class="mobile-total-wrap">
      <strong id="mobileTotal">0 ₽</strong>
      <span id="mobileCount">0 форматов</span>
    </div>
    <button type="button" class="button mobile-submit" id="submitOrderBtn">Оформить заказ</button>
  </div>

  <template id="formatPanelTemplate">
    <section class="selected-format-panel glow-panel is-visible" data-upload-row="__FORMAT__">
      <div class="selected-format-head">
        <div class="selected-format-title">
          <span class="format-badge">__FORMAT__</span>
          <strong>Файлы __FORMAT__</strong>
        </div>
        <button type="button" class="remove-format-btn" data-remove-format="__FORMAT__">×</button>
      </div>
      <div class="upload-row-body" style="max-height:none;opacity:1;padding:12px 16px 16px;">
        <label class="format-upload-drop">
          <span>Загрузить файлы</span>
          <small>PDF, DOC, JPG, PNG, TIFF, PSD, AI, CDR</small>
          <input class="format-file-input" type="file" multiple name="files___FORMAT__" data-format-input="__FORMAT__" />
        </label>
        <div class="file-tags" data-file-list="__FORMAT__"></div>
        <div class="row-grid row-grid-compact">
          <div class="field"><label>Печать</label><select data-prop="printType"><option value="bw">Ч/Б</option><option value="color">Цвет</option></select></div>
          <div class="field"><label>Заполнение</label><select data-prop="fillScale"><option value="scale1">До 5%</option><option value="scale2">5–50%</option><option value="scale3">От 50%</option></select></div>
          <div class="field"><label>Стороны</label><select data-prop="sides"><option value="single">1 сторона</option><option value="double">2 стороны</option></select></div>
          <div class="field"><label>Копии</label><input type="number" min="1" value="1" data-prop="copies" /></div>
          <div class="field"><label>Листы</label><input type="number" min="1" value="1" data-prop="pages" /></div>
        </div>
        <div class="quick-actions">
          <button type="button" class="tiny-button" data-action="same-file">Как в файле</button>
          <button type="button" class="tiny-button" data-action="one-copy">1 копия</button>
          <button type="button" class="tiny-button" data-action="double">Двусторонняя</button>
        </div>
        <div class="field"><label>Комментарий к формату</label><textarea data-prop="comment" placeholder="Комментарий"></textarea></div>
      </div>
    </section>
  </template>

  <script>
    const priceTable = <%- JSON.stringify(priceTable) %>;
    const selectedFormatsWrap = document.getElementById('selectedFormatsWrap');
    const template = document.getElementById('formatPanelTemplate').innerHTML;
    const selected = new Map();
    const orderForm = document.getElementById('orderForm');
    const formatsJson = document.getElementById('formatsJson');
    const summaryList = document.getElementById('summaryList');
    const estimateTotal = document.getElementById('estimateTotal');
    const estimateNote = document.getElementById('estimateNote');
    const mobileTotal = document.getElementById('mobileTotal');
    const mobileCount = document.getElementById('mobileCount');

    function createFormatState(format) {
      return { format, printType:'bw', fillScale:'scale1', sides:'single', copies:1, pages:1, comment:'', files:[], autoPages:true };
    }

    function renderPanel(format) {
      if (document.querySelector(`[data-upload-row="${format}"]`)) return;
      selectedFormatsWrap.insertAdjacentHTML('beforeend', template.replaceAll('__FORMAT__', format));
      const panel = document.querySelector(`[data-upload-row="${format}"]`);
      const state = selected.get(format);
      const input = panel.querySelector('[data-format-input]');
      const controls = panel.querySelectorAll('[data-prop]');
      const fileList = panel.querySelector('[data-file-list]');

      panel.querySelector('[data-remove-format]').addEventListener('click', () => {
        selected.delete(format);
        document.querySelector(`[data-format-toggle="${format}"]`)?.classList.remove('is-active');
        panel.remove();
        updateAll();
      });

      controls.forEach((el) => {
        el.addEventListener(el.tagName === 'TEXTAREA' ? 'input' : 'change', () => {
          state[el.dataset.prop] = el.type === 'number' ? Math.max(1, Number(el.value) || 1) : el.value;
          if (el.dataset.prop === 'pages') state.autoPages = false;
          updateAll();
        });
      });

      panel.querySelectorAll('[data-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const action = btn.dataset.action;
          if (action === 'same-file') {
            state.autoPages = true;
            state.pages = await detectPages(state.files);
            panel.querySelector('[data-prop="pages"]').value = state.pages;
          }
          if (action === 'one-copy') {
            state.copies = 1;
            panel.querySelector('[data-prop="copies"]').value = 1;
          }
          if (action === 'double') {
            state.sides = 'double';
            panel.querySelector('[data-prop="sides"]').value = 'double';
          }
          updateAll();
        });
      });

      input.addEventListener('change', async (e) => {
        const dt = new DataTransfer();
        const merged = [...state.files, ...Array.from(e.target.files || [])];
        state.files = merged;
        for (const file of merged) dt.items.add(file);
        input.files = dt.files;
        state.files = Array.from(input.files);
        if (state.autoPages) {
          state.pages = await detectPages(state.files);
          panel.querySelector('[data-prop="pages"]').value = state.pages;
        }
        renderFileList(format, fileList, input);
        updateAll();
      });

      renderFileList(format, fileList, input);
    }

    function renderFileList(format, node, input) {
      const state = selected.get(format);
      node.innerHTML = '';
      if (!state.files.length) {
        node.innerHTML = '<div class="file-pill muted">Файлов пока нет</div>';
        return;
      }
      state.files.forEach((file, index) => {
        const row = document.createElement('div');
        row.className = 'file-pill';
        row.innerHTML = `<span>${file.name}</span><button type="button">×</button>`;
        row.querySelector('button').addEventListener('click', async () => {
          state.files.splice(index, 1);
          const dt = new DataTransfer();
          state.files.forEach((f) => dt.items.add(f));
          input.files = dt.files;
          if (state.autoPages) {
            state.pages = await detectPages(state.files);
            document.querySelector(`[data-upload-row="${format}"] [data-prop="pages"]`).value = state.pages;
          }
          renderFileList(format, node, input);
          updateAll();
        });
        node.appendChild(row);
      });
    }

    async function detectPages(files) {
      if (!files.length) return 1;
      let total = 0;
      for (const file of files) {
        const ext = (file.name.split('.').pop() || '').toLowerCase();
        if (ext === 'pdf' && window.PDFLib) {
          try {
            const bytes = await file.arrayBuffer();
            const pdf = await PDFLib.PDFDocument.load(bytes);
            total += pdf.getPageCount();
            continue;
          } catch {}
        }
        total += 1;
      }
      return Math.max(1, total);
    }

    function rowTotal(row) {
      const base = priceTable[row.printType]?.[row.fillScale]?.[row.format] ?? null;
      if (base == null) return 0;
      return Math.round(base * row.copies * row.pages * (row.sides === 'double' ? 1.8 : 1));
    }

    function updateSummary() {
      const rows = Array.from(selected.values()).filter((row) => row.files.length > 0);
      const total = rows.reduce((sum, row) => sum + rowTotal(row), 0);
      summaryList.innerHTML = rows.length ? rows.map((row) => `
        <div class="summary-file-row has-files">
          <span>${row.format} · ${row.printType === 'bw' ? 'Ч/Б' : 'Цвет'} · ${row.copies} коп.</span>
          <strong>${new Intl.NumberFormat('ru-RU').format(rowTotal(row))} ₽</strong>
        </div>`).join('') : '<div class="summary-file-row"><span>Пока пусто</span><strong>0</strong></div>';
      const totalLabel = `${new Intl.NumberFormat('ru-RU').format(total)} ₽`;
      estimateTotal.textContent = totalLabel;
      estimateNote.textContent = rows.length ? `${rows.length} форматов` : 'Добавь файлы';
      mobileTotal.textContent = totalLabel;
      mobileCount.textContent = rows.length ? `${rows.length} форматов` : '0 форматов';
    }

    function updateAll() {
      const payload = Array.from(selected.values()).map((row) => ({
        format: row.format,
        printType: row.printType,
        fillScale: row.fillScale,
        sides: row.sides,
        copies: row.copies,
        pages: row.pages,
        comment: row.comment,
        fileCount: row.files.length,
        filesExpected: true,
      }));
      formatsJson.value = JSON.stringify(payload);
      updateSummary();
    }

    document.querySelectorAll('[data-format-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const format = button.dataset.formatToggle;
        if (selected.has(format)) {
          selected.delete(format);
          document.querySelector(`[data-upload-row="${format}"]`)?.remove();
          button.classList.remove('is-active');
        } else {
          selected.set(format, createFormatState(format));
          renderPanel(format);
          button.classList.add('is-active');
        }
        updateAll();
      });
    });

    document.getElementById('submitOrderBtn').addEventListener('click', () => orderForm.requestSubmit());
    document.getElementById('deliveryType').addEventListener('change', (e) => {
      document.getElementById('addressField').style.display = e.target.value === 'delivery' ? 'grid' : 'none';
    });

    updateAll();
  </script>
</body>
</html>
